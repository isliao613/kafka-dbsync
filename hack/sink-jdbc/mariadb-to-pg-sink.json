{
    "name": "sink_cdc_mariadb_to_pg",
    "config": {
        "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
        "tasks.max": "1",
        "topics": "cdc_mariadb.source_database.source_orders",
        "connection.url": "jdbc:postgresql://dbrep-postgres-postgresql.dev.svc.cluster.local:5432/target_database",
        "connection.user": "postgres",
        "connection.password": "postgres_password",
        "insert.mode": "upsert",
        "delete.enabled": "true",
        "pk.mode": "record_key",
        "pk.fields": "id",
        "auto.create": "true",
        "auto.evolve": "true",
        "table.name.format": "mariadb_source_orders",
        "key.converter": "org.apache.kafka.connect.json.JsonConverter",
        "value.converter": "org.apache.kafka.connect.json.JsonConverter",
        "key.converter.schemas.enable": "true",
        "value.converter.schemas.enable": "true"
    }
}
